                        "meta": {
                          "type": "object",
                          "properties": {
                            "endOfReader": {
                              "type": "boolean",
                              "description": "<p>When true, no more endpoints are available when calling this route with a higher minimumAssetId.</p>"
                            },
                            "message": {
                              "type": "object",
                              "properties": {
                                "code": {
                                  "type": "string",
                                  "description": ""
                                },
                                "text": {
                                  "type": "string",
                                  "description": ""
                                }
                              },
                              "description": "<p>An optional message describing the data in more details in unusual situations.</p>",
                              "required": [
                                "code",
                                "text"
                              ]
                            },
                            "nextAssetId": {
                              "type": "number",
                              "description": "<p>An id greater than the largest id in the returned data set. Omitted if the data set is empty. If paging through data, pass this value as the minimumAssetId in subsequent calls.  If used, may not result in additional data.</p>"
                            }
                          },
                          "description": "<p>meta information about the asset data returned.</p>",
                          "required": [
                            "endOfReader",
                            "message",
                            "nextAssetId"
                          ]
                        }
                      },
                      "description": "",
                      "required": [
                        "data",
                        "meta"
                      ]
                    }
                  },
                  "type": "object",
                  "required": [
                    "response"
                  ]
